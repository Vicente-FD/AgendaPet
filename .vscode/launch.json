{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Agenda Pet (Web Server :3000)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "web-server",
        "--web-port=3000",
        "--web-hostname=localhost"
      ]
    },
    {
      "name": "Agenda Pet (Edge :3000)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "edge",
        "--web-port=3000",
        "--web-hostname=localhost"
      ]
    }
  ]
}
